  <property name="styleSheet">
   <string notr="true">* {
    color: black;
    font: 10pt &quot;Inter&quot;;
    background-color: rgb(222, 221, 218);
}

*[class=&quot;button-green&quot;] {
    border-radius: 15px;
    padding: 0px 10px 0px;
    background: #129046;
    color: #FFF;
	font: 10pt &quot;Inter SemiBold&quot;;
}

*[class=&quot;button-green&quot;]:hover {
    background: #27AE60;
}

QComboBox[class=&quot;combobox-main&quot;] {
	height: 30px;
	border: 1px solid #999;
	border-radius: 15px;
    padding-left: 10px;
    background-color: #ffffff;
    color: #333333;
    font-size: 12px;
    selection-background-color: #7eb4d7;
	font: 10pt &quot;Inter&quot;;
}

QComboBox[class=&quot;combobox-main&quot;]:focus {
	border: 1px solid #007BFF;
}

QComboBox[class=&quot;combobox-main&quot;]:hover {
    border: 1px solid #3498db;
}

QComboBox[class=&quot;combobox-main&quot;]::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: top right;
    width: 30px;
    border-left-width: 0px;
    border-top-right-radius: 8px;
    border-bottom-right-radius: 8px;
}

QComboBox[class=&quot;combobox-main&quot;]::down-arrow {
    image: url(:/Images/Images/caret-down.png);
    border: none;
    width: 8px;
    height: 8px;
}

QComboBox[class=&quot;combobox-main&quot;] QAbstractItemView {
    background-color: #ffffff;
    selection-background-color: #7eb4d7;
    selection-color: #ffffff;
    border-radius: 5px;
}

QComboBox[class=&quot;combobox-main&quot;] QAbstractItemView::item {
    min-height: 35px;
    padding-left: 10px;
    border-radius: 4px;
}

QSpinBox {
    height: 30px;
    border: 1px solid #999;
    border-radius: 15px;
    padding: 0px 5px 0px;
    background-color: #ffffff;
    color: #333333;
    font-size: 12px;
    selection-background-color: #7eb4d7;
	font: 10pt &quot;Inter&quot;;
}

QSpinBox:focus {
    border: 1px solid #007BFF;
}

QSpinBox:hover {
    border: 1px solid #3498db;
}

QSpinBox::up-button {
    subcontrol-origin: border;
    subcontrol-position: top right;
    width: 8px;
    height: 8px;
    border-top-right-radius: 15px;
    padding: 6px 10px 6px 2px;
	color: rgb(119, 118, 123);
}

QSpinBox::down-button {
    subcontrol-origin: border;
    subcontrol-position: bottom right;
    width: 8px;
    height: 8px;
    border-bottom-right-radius: 15px;
    padding: 6px 10px 6px 2px;
	color: rgb(119, 118, 123);
}

QSpinBox::up-arrow {
    image: url(:/Images/Images/caret-up.png);
    width: 8px;
    height: 8px;
}

QSpinBox::down-arrow {
    image: url(:/Images/Images/caret-down.png);
    width: 8px;
    height: 8px;
}
</string>
