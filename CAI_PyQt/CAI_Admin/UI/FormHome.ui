            <widget class="QWidget" name="widget_4" native="true">
             <property name="styleSheet">
              <string notr="true">/* Base style for all difficulty buttons */
QPushButton {
    border: 1px solid #999;
    padding: 5px 15px;
	font: 10pt &quot;Inter&quot;;
    background-color: #f0f0f0; /* Default neutral color */
}

/* LEFT BUTTON (Easy) */
QPushButton#btnEasy {
    border-top-left-radius: 6px;
    border-bottom-left-radius: 6px;
    border-right: none; /* Avoid double borders in the middle */
}
QPushButton#btnEasy:checked {
    background-color: #72D582; /* Green */
	border: 2px solid #448D50;
    color: #000;
}

/* MIDDLE BUTTON (Average) */
QPushButton#btnAverage {
    border-radius: 0px;
    border-right: none;
}
QPushButton#btnAverage:checked {
	background-color: #FFF2AC; /* Yellow */
	border: 2px solid #FCB988;
	color: #000;
}

/* RIGHT BUTTON (Hard) */
QPushButton#btnHard {
    border-top-right-radius: 6px;
    border-bottom-right-radius: 6px;
}
QPushButton#btnHard:checked {
	background-color: #F07D75; /* Red */
	border: 2px solid #E65247;
	color: #000;
}

/* Hover effect */
QPushButton:hover {
    background-color: #e0e0e0;
}</string>
