        <item>
         <widget class="QTabWidget" name="tabWidget_2">
          <property name="styleSheet">
           <string notr="true">QTableView {
    border: 1px solid #ff7d87;
    gridline-color: #f0f0f0;
    background-color: white;
    selection-background-color: rgba(255, 125, 135, 0.2); /* Transparent coral highlight */
    selection-color: black;
    outline: none;
}

/* Hide the row numbers (Vertical Header) */
QHeaderView:vertical {
    width: 0px;
}

QHeaderView::section:vertical {
    width: 0px;
    border: none;
}

/* Style the top horizontal header with the #ff7d87 theme */
QHeaderView::section:horizontal {
    background-color: #ff7d87;  
    color: white;
    padding: 6px;
    font-weight: bold;
    font-size: 11pt;
    border: none;
}

/* Hide top-left corner button by matching header color */
QTableCornerButton::section {
    background-color: #ff7d87;
    border: none;
}

/* Custom Scrollbars */
QScrollBar:vertical {
    border: none;
    background: #fdfdfd;
    width: 10px;
}

QScrollBar::handle:vertical {
    background: #ff7d87;
    min-height: 30px;
    border-radius: 5px; 
    margin: 2px;
}

QScrollBar::handle:vertical:hover {
    background: #e66a74; /* Slightly darker shade for hover effect */
}

QScrollBar:horizontal {
    border: none;
    background: #fdfdfd;
    height: 10px;
}

QScrollBar::handle:horizontal {
    background: #ff7d87;
    min-width: 30px;
    border-radius: 5px;
    margin: 2px;
}

QScrollBar::handle:horizontal:hover {
    background: #e66a74;
}

/* Remove scrollbar arrows and extra space */
QScrollBar::add-line, QScrollBar::sub-line {
    width: 0px; height: 0px;
    background: none;
    border: none;
}

QScrollBar::add-page, QScrollBar::sub-page {
    background: none;
}</string>
