           <item>
            <widget class="QScrollArea" name="scrollArea">
             <property name="autoFillBackground">
              <bool>true</bool>
             </property>
             <property name="styleSheet">
              <string notr="true">/* 1. THE MAIN CONTAINER */
#scrollArea { 
    border: none;
    border-radius: 20px;
	background-color: rgb(246, 245, 244);
}

/* 2. THE VIEWPORT (Crucial for transparency/backgrounds) */
#scrollArea QWidget #qt_scrollarea_viewport {
    background: transparent;
    border-radius: 20px;
}

/* 3. VERTICAL SCROLLBAR */
QScrollBar:vertical {
    border: none;
    background: #ffffff;
    width: 10px;
    margin: 0px;
    border-radius: 5px;
}

QScrollBar::handle:vertical {
    background: #7a7a7a;
    min-height: 20px;
    border-radius: 5px;
}

QScrollBar::handle:vertical:hover {
    background: #574939;
}

/* 4. HORIZONTAL SCROLLBAR */
QScrollBar:horizontal {
    border: none;
    background: #ffffff;
    height: 10px; /* Note: height, not width */
    margin: 0px;
    border-radius: 5px;
}

QScrollBar::handle:horizontal {
    background: #7a7a7a;
    min-width: 20px;
    border-radius: 5px;
}

QScrollBar::handle:horizontal:hover {
    background: #574939;
}

/* 5. REMOVE BUTTONS &amp; TRACK BACKGROUNDS */
/* This handles both horizontal and vertical arrows/tracks */
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical,
QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal {
    border: none;
    background: none;
    width: 0px;
    height: 0px;
}

QScrollBar::add-page:vertical, QScrollBar::sub-page:vertical,
QScrollBar::add-page:horizontal, QScrollBar::sub-page:horizontal {
    background: none;
}

/* 6. THE CORNER WIDGET 
   (The small square where both bars meet) */
#scrollArea QWidget #qt_scrollarea_corner {
    background: transparent;
    border: none;
}</string>
             </property>
