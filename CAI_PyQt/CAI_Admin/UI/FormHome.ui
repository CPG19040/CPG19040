          <property name="styleSheet">
           <string notr="true">QTableView {
    border: 1px solid rgb(38, 162, 105);
    gridline-color: #f0f0f0;
    background-color: white;
    selection-background-color: rgba(38, 162, 105, 0.2);
    selection-color: black;
    outline: none;
}

/* Remove the row numbers (Vertical Header) */
QHeaderView:vertical {
    width: 0px;
}

QHeaderView::section:vertical {
    width: 0px;
    border: none;
}

/* Style the top horizontal header */
QHeaderView::section:horizontal {
    background-color: rgb(38, 162, 105);  
    color: white;
    padding: 6px;
    font-weight: bold;
    font-size: 11pt;
    border: none;
}

/* Custom Scrollbars */
QScrollBar:vertical {
    border: none;
    background: #f8f8f8;
    width: 10px;
}

QScrollBar::handle:vertical {
    background: rgb(38, 162, 105);
    min-height: 30px;
    border-radius: 5px; 
    margin: 2px;
}

QScrollBar:horizontal {
    border: none;
    background: #f8f8f8;
    height: 10px;
}

QScrollBar::handle:horizontal {
    background: rgb(38, 162, 105);
    min-width: 30px;
    border-radius: 5px;
    margin: 2px;
}

/* Remove scrollbar arrows */
QScrollBar::add-line, QScrollBar::sub-line {
    width: 0px; height: 0px;
}</string>
          </property>
