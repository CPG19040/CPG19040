     <property name="styleSheet">
      <string notr="true">* {
	font: 10pt &quot;Inter&quot;;
}

#Card {
	background-color: #FFF;
	border-radius: 10px;
	border: 1px solid #ddd;
}

QLabel {
	color: #333;
}

#widget_header {
	background-color: rgb(153, 193, 241);
	border-top-left-radius: 10px;
	border-top-right-radius: 10px;
}

#label_itemno {
	font: 10pt &quot;Inter SemiBold&quot;;
}

#btn_delete {
	background-color: rgb(255, 255, 255);
	color: red; 
	font-weight: bold;
	font: 12pt &quot;Inter&quot;;
	border-radius: 15px;
}

#btn_delete:hover {
	color: white;
	background-color: red;
}

#btn_q_image {
	background-color: white;
	border: none;
}

#btn_q_image:hover {
	background-color: rgb(208, 236, 255);
	border: none;
}

#btn_upload_img {
	border: none;
	color: blue;
	background-color: transparent; 
	margin: 0px 20px 0px;
}

#plainTextEdit, #txt_question {
	background-color: white;
	border-radius: 15px;
	padding: 0px 10px 0px;
	border: 1px solid #ABABAB;
}

#plainTextEdit:hover, #txt_question:hover {
	border: 2px solid #3498db;
}

#txt_question:focus {
	border: 2px solid #007BFF;
}</string>
